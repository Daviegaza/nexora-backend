# ── Core ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# ── Postgres ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nexora:nexora@localhost:5432/nexora?schema=public

# ── Redis (BullMQ queue + rate-limit) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_different_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,https://app.nexora.co.ke

# ── KRA eTIMS ─────────────────────────────────────────────────────────────
KRA_ETIMS_BASE_URL=https://etims-api-sbx.kra.go.ke
KRA_ETIMS_TIN=
KRA_ETIMS_BHF_ID=00
KRA_ETIMS_PIN=
KRA_ETIMS_API_KEY=

# ── M-Pesa (Daraja) ───────────────────────────────────────────────────────
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_BASE=https://api.nexora.co.ke

# ── AI provider ───────────────────────────────────────────────────────────
AI_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5-20251001
AI_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────
S3_ENDPOINT=
S3_BUCKET=nexora-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Notifications ─────────────────────────────────────────────────────────
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
